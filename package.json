{
  "name": "secflow",
  "version": "0.1.0",
  "description": "An LLM harness designed for application security engineers and application defenders.",
  "type": "module",
  "bin": {
    "secflow": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
